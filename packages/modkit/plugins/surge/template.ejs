<% SurgeModule.Metadata(metadata, arguments) %>

<% if (content.general) { %>
[General]
<% SurgeModule.General(content.general) %>
<% } %>

<% if (content.rule) { %>
[Rule]
<% SurgeModule.Rule(content.rule) %>
<% } %>

<% if (content.rewrite) { %>
<% {urlRewrite, headerRewrite, bodyRewrite } = SurgeModule.Rewrite(content.rewrite) %>
[URL Rewrite]
<% urlRewrite %>

[Header Rewrite]
<% headerRewrite %>

[Body Rewrite]
<% bodyRewrite %>
<% } %>

<% if (content.mock) { %>
[Map Local]
<% SurgeModule.Mock(content.mock) %>
<% } %>

<% if (content.script) { %>
[Script]
<% SurgeModule.Script(content.script, getScriptPath(compilation, undefined, assetPrefix), cscriptParams) %>
<% } %>

<% if (content.mitm && content.mitm.hostname) { %>
[Mitm]
<% SurgeModule.MitM(content.mitm) %>
<% } %>
